# DMXAPI — https://doc.dmxapi.cn/fanwei.html

# AI 解读专用（抽牌解析，/api/reading 仅使用此项）
DMXAPI_READING_KEY=sk-your-key-here
DMXAPI_READING_MODEL=deepseek-v4-flash
DMXAPI_READING_BASE=https://www.dmxapi.com

# 文生图 / 卡面脚本（可与 READING_KEY 相同）
DMXAPI_KEY=sk-your-key-here
DMXAPI_MODEL=deepseek-v4-flash
DMXAPI_BASE=https://www.dmxapi.com

# 文生图（卡面）— 主模型失败时自动回退到 DMXAPI_IMAGE_FALLBACK 中的其他模型
# 查看: node scripts/generate-card-images.mjs --list-models
# 回退链: node scripts/generate-card-images.mjs --list-fallback
DMXAPI_IMAGE_MODEL=gpt-image-2-ssvip
DMXAPI_IMAGE_FALLBACK=gpt-image-1.5,gpt-image-1,doubao-seedream-4-0-250828,seedream-3.0,dall-e-3,flux-kontext-pro,flux-kontext-max,imagen4
DMXAPI_IMAGE_BASE=https://www.dmxapi.cn
DMXAPI_IMAGE_SIZE=1024x1536
DMXAPI_REVIEW_MODEL=gpt-4o
REVERSE_RATE=0.32
ORIENT_MODE=linked
